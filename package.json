{
  "name": "openclaw-feishu-stream",
  "version": "0.1.0-dev",
  "private": true,
  "description": "OpenClaw Feishu streaming card plugin fork for OpenClaw 2026.5.x",
  "main": "./dist/index.js",
  "type": "module",
  "bin": {
    "openclaw-feishu-stream": "bin/openclaw-feishu-stream.js"
  },
  "files": [
    "bin/",
    "dist/",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "release": "node scripts/release.mjs",
    "dev:configure": "node scripts/configure-dev-profile.mjs",
    "dev:link": "openclaw --profile feishu-stream-dev plugins install --link .",
    "dev:doctor": "openclaw --profile feishu-stream-dev plugins doctor",
    "dev:inspect": "openclaw --profile feishu-stream-dev plugins inspect openclaw-feishu-stream --runtime",
    "dev:gateway": "openclaw --profile feishu-stream-dev gateway run --port 19002 --force",
    "lint": "eslint src/ index.ts",
    "lint:fix": "eslint src/ index.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "format:check": "prettier --check src/**/*.ts"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "@sinclair/typebox": "0.34.48",
    "image-size": "^2.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "@types/qrcode": "^1.5.5",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "esbuild": "^0.27.4",
    "eslint": "^9.39.3",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^17.24.0",
    "execa": "^9.6.0",
    "fs-extra": "^11.3.2",
    "minimist": "^1.2.8",
    "openclaw": "2026.5.22",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "channel": {
      "id": "feishu",
      "label": "Feishu",
      "selectionLabel": "Lark/Feishu (飞书)",
      "docsPath": "/channels/feishu",
      "docsLabel": "feishu",
      "blurb": "飞书/Lark enterprise messaging with doc/wiki/drive/task/calendar tools.",
      "aliases": [
        "lark"
      ],
      "order": 35,
      "quickstartAllowFrom": true
    },
    "install": {
      "npmSpec": "openclaw-feishu-stream",
      "localPath": "extensions/openclaw-feishu-stream",
      "defaultChoice": "npm"
    }
  }
}
